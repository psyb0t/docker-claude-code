# Claudebox cron configuration
# Copy somewhere accessible (e.g. ~/.claude/cron.yaml) and point CLAUDEBOX_MODE_CRON_FILE at it.
#
# Run with:
#   CLAUDEBOX_MODE_CRON=1 CLAUDEBOX_MODE_CRON_FILE=/home/claude/.claude/cron.yaml claudebox
# or via docker-compose (see README).
#
# Each job fires `claude -p "<instruction>"` on schedule. Output streams to
# ~/.claude/cron/history/<workspace-slug>/<YYYYMMDD-HHMMSS>-<job-name>/activity.jsonl
# alongside stderr.log and meta.json.
#
# Workspace: CLAUDEBOX_WORKSPACE env var (wrapper sets it to $PWD). All jobs share one workspace.
#
# Cron syntax:
#   5-field "min hr dom mon dow"        — standard cron, minute resolution
#   6-field "sec min hr dom mon dow"    — sub-minute resolution (e.g. */30 fires every 30s)
#
# Root-level fields set defaults for all jobs. Per-job fields override them.
#
# Template variables (expanded at fire time):
#   {system_datetime} — current UTC datetime, e.g. "2026-04-29 14:35:00 UTC"
#   {job_name}        — the job's name field
#
# Works in: instruction, system_prompt, append_system_prompt
#
# Telegram notifications: set telegram_chat_id (root or per-job) + env
# CLAUDEBOX_TELEGRAM_BOT_TOKEN to send Claude's result to a Telegram chat
# after each job finishes.

model: haiku                        # default model for all jobs
append_system_prompt: |             # appended to system prompt for all jobs
  The current date and time is {system_datetime}.
# telegram_chat_id: -1001234567890  # send all job results here by default

jobs:
  - name: every_thirty_seconds
    schedule: "*/30 * * * * *"      # 6-field — every 30 seconds
    instruction: |
      Write the current UTC timestamp to ./status.txt.

  - name: hourly_repo_check
    schedule: "0 * * * *"
    model: sonnet                   # override: use sonnet for this job
    # telegram_chat_id: -1001234567890  # per-job override
    instruction: |
      Look at the git log for the last hour. Summarize commits.

  - name: nightly_cleanup
    schedule: "0 3 * * *"
    model: opus
    system_prompt: |                # override: replace system prompt entirely for this job
      You are a cleanup agent. Current time: {system_datetime}.
      Your only job is to find and delete stale files.
    instruction: |
      Find files older than 7 days under ./tmp and delete them.
      Report what you removed.
